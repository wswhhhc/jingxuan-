# ============================================================
# 测试环境变量模板
# 复制为 .env 并填入实际值，或直接在系统中设置环境变量
# ============================================================

# MySQL 数据库密码（application-test.yml 使用 H2 无需此变量）
# DB_PASSWORD=your_password_here

# DeepSeek API Key（测试环境 fallback=bypass，通常无需真实 Key）
# DEEPSEEK_API_KEY=sk-your-key-here
