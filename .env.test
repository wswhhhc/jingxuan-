# ============================================================
# 测试环境变量模板
# 复制此文件为 .env 并填入真实值
# 注意：不要将包含真实 API Key 的 .env 提交到 Git
# ============================================================

# DeepSeek 内容审核 API Key（测试环境可用空值配合 fallback=bypass）
DEEPSEEK_API_KEY=

# MySQL 数据库密码（测试环境用 H2 内存数据库，可留空）
DB_PASSWORD=
